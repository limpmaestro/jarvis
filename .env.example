# Jarvis configuration — copy to .env and edit.
# Everything here can also be overridden via real env vars at runtime.

# --- Core ---
JARVIS_LOG_LEVEL=INFO
JARVIS_LANGUAGE=auto             # auto | sv | en
JARVIS_STATE_DIR=~/.jarvis/state

# --- Ollama ---
# Where the daemon listens. Defaults to WSL loopback. If you run Ollama on
# the Windows side (default install or OneDrive-redirected %LOCALAPPDATA%),
# point this at the WSL gateway IP, e.g. http://172.30.16.1:11434, OR enable
# WSL mirrored networking in .wslconfig and keep 127.0.0.1.
OLLAMA_HOST=http://127.0.0.1:11434
# Set to 1 to make scripts/install.sh leave Ollama completely alone
# (no install, no `ollama serve`, no model pulls via local CLI).
# JARVIS_SKIP_OLLAMA_INSTALL=1
JARVIS_MODEL=jarvis              # the Modelfile-derived tag
JARVIS_EMBED_MODEL=nomic-embed-text:v1.5
JARVIS_NUM_CTX=8192
JARVIS_TEMPERATURE=0.4

# --- STT ---
JARVIS_STT_MODEL=large-v3-turbo  # auto-downgrades to medium if VRAM < 10 GB
JARVIS_STT_DEVICE=cuda           # cuda | cpu
JARVIS_STT_COMPUTE_TYPE=float16  # float16 | int8_float16 | int8
JARVIS_WAKE_WORD=hey_jarvis      # set to "" to disable; use push-to-talk only
JARVIS_PTT_HOTKEY=F8

# --- TTS ---
JARVIS_TTS_VOICE_SV=sv_SE-nst-medium
JARVIS_TTS_VOICE_EN=en_US-amy-medium
JARVIS_TTS_RATE=1.0

# --- Tools ---
JARVIS_ALLOWED_ROOTS=~/Documents,~/Downloads,~/Desktop,/mnt/c/Users
JARVIS_TOOL_TIMEOUT_SEC=30
JARVIS_UNATTENDED=false          # if true, high-risk tools skip confirmation

# --- Windows bridge ---
JARVIS_BRIDGE_HOST=127.0.0.1
JARVIS_BRIDGE_PORT=48219
# JARVIS_BRIDGE_HMAC=<set automatically by install.sh; stored in vault>

# --- HUD ---
JARVIS_HUD_ENABLED=true
JARVIS_HUD_POSITION=top-right    # top-left | top-right | bottom-left | bottom-right | remembered

# --- Memory ---
JARVIS_MEMORY_TOPK=6
JARVIS_MEMORY_HALF_LIFE_DAYS=14
